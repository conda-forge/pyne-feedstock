From 3f37914f28aa9cb90e1d9fd831088ff2fe3c4a09 Mon Sep 17 00:00:00 2001
From: Matthew Feickert <matthew.feickert@cern.ch>
Date: Wed, 18 Feb 2026 09:46:21 -0700
Subject: [PATCH] fix: resolve 23 nose test failures for Python 3.11/NumPy 2.x
 compatibility
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- endf.pyx: Fix import — OrderedDict lives in collections, not
  collections.abc; keeps Iterable from collections.abc with fallback
- openmc_utils.py: Replace deprecated np.reshape(newshape=...) with
  positional shape arg (removed in NumPy 2.0)
- material.pyx: Replace Cython 2 dual-dispatch __add__/__mul__ pattern
  with proper Python 3 __add__/__radd__ and __mul__/__rmul__ methods so
  that int+Material and float*Material work via reflected operand protocol
- tests/test_nucname.py, test_rxname.py, test_material.py: Accept
  UnicodeDecodeError alongside RuntimeError for C++ exception tests;
  Cython 3 strictly UTF-8 decodes .what() and may raise UnicodeDecodeError
  instead of RuntimeError when message bytes are not valid UTF-8
- tests/test_openmc_utils.py: Build inhomogeneous object array with
  np.empty(dtype=object) + assignment; NumPy 2.0 raises ValueError for
  ragged sequences passed directly to np.array()
- tests/transmute/test_chainsolve.py: Remove numpy.testing.dec import
  (removed in NumPy 1.24); dec was imported but never used
---
 pyne/endf.pyx                      |  5 +--
 pyne/material.pyx                  | 50 ++++++++++++++++++------------
 pyne/openmc_utils.py               |  4 +--
 tests/test_material.py             |  2 +-
 tests/test_nucname.py              |  4 +--
 tests/test_openmc_utils.py         |  7 +++--
 tests/test_rxname.py               | 20 ++++++------
 tests/transmute/test_chainsolve.py |  2 +-
 8 files changed, 53 insertions(+), 41 deletions(-)

diff --git a/pyne/endf.pyx b/pyne/endf.pyx
index a0ee1368..2dc366db 100644
--- a/pyne/endf.pyx
+++ b/pyne/endf.pyx
@@ -15,10 +15,11 @@ from __future__ import print_function, division, unicode_literals
 
 import re
 import os
+from collections import OrderedDict
 try:
-    from collections.abc import OrderedDict, Iterable
+    from collections.abc import Iterable
 except ImportError:
-    from collections import OrderedDict, Iterable
+    from collections import Iterable
 from warnings import warn
 from pyne.utils import QA_warn
 
diff --git a/pyne/material.pyx b/pyne/material.pyx
index 37921e9a..8b840712 100644
--- a/pyne/material.pyx
+++ b/pyne/material.pyx
@@ -1394,17 +1394,23 @@ cdef class _Material:
         return pymat
 
 
-    def __add__(x, y):
-        if isinstance(x, _Material) and isinstance(y, _Material):
-            return x.__add_material__(y)
-        elif isinstance(y, float):
-            return x.__add_float__(y)
-        elif isinstance(x, float):
-            return y.__add_float__(x)
-        elif isinstance(y, int):
-            return x.__add_float__(float(y))
-        elif isinstance(x, int):
-            return y.__add_float__(float(x))
+    def __add__(self, other):
+        if isinstance(other, _Material):
+            return self.__add_material__(other)
+        elif isinstance(other, float):
+            return self.__add_float__(other)
+        elif isinstance(other, int):
+            return self.__add_float__(float(other))
+        else:
+            return NotImplemented
+
+    def __radd__(self, other):
+        if isinstance(other, _Material):
+            return other.__add_material__(self)
+        elif isinstance(other, float):
+            return self.__add_float__(other)
+        elif isinstance(other, int):
+            return self.__add_float__(float(other))
         else:
             return NotImplemented
 
@@ -1417,15 +1423,19 @@ cdef class _Material:
         return pymat
 
 
-    def __mul__(x, y):
-        if isinstance(y, float):
-            return x.__mul_float__(y)
-        elif isinstance(x, float):
-            return y.__mul_float__(x)
-        elif isinstance(y, int):
-            return x.__mul_float__(float(y))
-        elif isinstance(x, int):
-            return y.__mul_float__(float(x))
+    def __mul__(self, other):
+        if isinstance(other, float):
+            return self.__mul_float__(other)
+        elif isinstance(other, int):
+            return self.__mul_float__(float(other))
+        else:
+            return NotImplemented
+
+    def __rmul__(self, other):
+        if isinstance(other, float):
+            return self.__mul_float__(other)
+        elif isinstance(other, int):
+            return self.__mul_float__(float(other))
         else:
             return NotImplemented
 
diff --git a/pyne/openmc_utils.py b/pyne/openmc_utils.py
index 74bdee93..3eeb5afc 100644
--- a/pyne/openmc_utils.py
+++ b/pyne/openmc_utils.py
@@ -375,7 +375,7 @@ def result_changes_order(result, dims):
     num_e_groups = result.size // (x_dim * y_dim * z_dim)
     # the original result, energy changes the fastest, x next, y next, then z
     # reshape result to 4 dimension (z, y, x, e, with e changes fastest) array
-    result_ = np.reshape(result, newshape=(z_dim, y_dim, x_dim, num_e_groups))
+    result_ = np.reshape(result, (z_dim, y_dim, x_dim, num_e_groups))
 
     # the target sequence, energy changes fastest, z next, y next, then x
     # move the axis from [0, 1, 2, 3] (z, y, x, e) to
@@ -384,7 +384,7 @@ def result_changes_order(result, dims):
 
     # reshape the 4 dimension (x, y, z, e, with e changes fastest) array to
     #             2 dimension (x_dim*y_dim*z_dim, num_e_groups) array
-    result_ = np.reshape(result_, newshape=(x_dim * y_dim * z_dim, num_e_groups))
+    result_ = np.reshape(result_, (x_dim * y_dim * z_dim, num_e_groups))
 
     return result_
 
