 src/data.cpp       | 24 ++++++++++++------------
 src/enrichment.cpp |  4 ++--
 src/material.cpp   |  4 ++--
 src/utils.h        | 12 ------------
 4 files changed, 16 insertions(+), 28 deletions(-)

