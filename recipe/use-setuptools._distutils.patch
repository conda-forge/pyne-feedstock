From c6dea0787eb68d058fee55bfb932d5c8bc7dbad3 Mon Sep 17 00:00:00 2001
From: Matthew Feickert <matthew.feickert@cern.ch>
Date: Tue, 17 Feb 2026 19:37:21 -0700
Subject: [PATCH] fix: Use setuptools._distutils.core over distutils

---
 setup.py | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/setup.py b/setup.py
index 50518001..cfb889bf 100755
--- a/setup.py
+++ b/setup.py
@@ -5,7 +5,7 @@ is a multilanguage project.  Still this script follows a predictable ordering:
 1. Parse command line arguments,
 2. Call cmake from the 'build' directory
 3. Call make from the 'build' directory
-4. Use distutils/setuptools from the 'build' directory
+4. Use setuptools from the 'build' directory
 
 This gives us the best of both worlds. Compiled code is installed with cmake/make
 and Cython/Python code is installed with normal Python tools. The only trick here is
@@ -44,7 +44,7 @@ import platform
 import warnings
 import subprocess
 from glob import glob
-from distutils import core, dir_util, sysconfig
+import sysconfig
 from contextlib import contextmanager
 if sys.version_info[0] < 3:
     from urllib import urlopen
@@ -149,8 +149,8 @@ def copy_ensdf_executables(exe_dest):
     # Hack for copying the executables the first time PyNE is installed, before
     # pyne has been added to the python path.
     if exe_dest[-4:] != 'pyne':
-        exe_dest = sysconfig.get_python_lib()
-        for f in os.listdir(sysconfig.get_python_lib()):
+        exe_dest = sysconfig.get_path('purelib')
+        for f in os.listdir(sysconfig.get_path('purelib')):
             if re.match('pyne', f):
                 exe_dest = exe_dest + '/' + f
         exe_dest = exe_dest + '/pyne'
@@ -224,7 +224,7 @@ def update_setup_args(ns):
     files = [DECAY_H, DECAY_CPP, CRAM_H, CRAM_C] + DECAY_S + CRAM_S
     if ns.cmd == 'clean':
         if os.path.exists(ns.build_dir):
-            dir_util.remove_tree(ns.build_dir)
+            shutil.rmtree(ns.build_dir)
         for f in files:
             if os.path.isfile(f):
                 print('deleting ' + f)
@@ -233,7 +233,7 @@ def update_setup_args(ns):
         sys.exit()
     if ns.clean:
         if os.path.exists(ns.build_dir):
-            dir_util.remove_tree(ns.build_dir)
+            shutil.rmtree(ns.build_dir)
         for f in files:
             if os.path.isfile(f):
                 print('deleting ' + f)
-- 
